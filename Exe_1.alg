algoritmo "semnome"
// Autor : Riquelme Reis
// Data : 07/04/2026
var
n1:real
n2:real
soma:real

inicio

// Seleção dos número
 escreva ("Digite um número: ")
 leia(n1)
 escreva ("Digite outro número: ")
 leia(n2)
 
// Soma dos número
soma <- n1+n2

// Resultado Final
escreva ("A soma de ", n1, " + ", n2, " é igual á ", soma)

fimalgoritmo
