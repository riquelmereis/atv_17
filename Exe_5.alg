algoritmo "IMC"
// Autor : Riquelme Reis
// Data : 07/04/2026

var

graus: real
fahrenheit: real


inicio
// Coleta de dados
    escreva ("Informe o valor dos graus Celsius (°C): ")
    leia(graus)

// Cálculo
    fahrenheit <- ((9 * graus)/5) + 32

// Resultado Final
   escreva ("O valor de ", graus, " é igual á ", fahrenheit," fahrenheit.")

fimalgoritmo
